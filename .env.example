# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# New dashboard: Publishable key — or use legacy anon JWT as NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_jwt

# Public app URL (no trailing slash). Used for invite email redirects, e.g. http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — never expose in client code or commit real values.
# Supabase → Project Settings → API → Project API keys → service_role (secret).
# Required for “Invite volunteers” in Settings and for storing landing-page “Request access” submissions.
# If unset, invitations and the public contact form insert will fail at runtime.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
